# Anthropic (Scene Planning)
ANTHROPIC_API_KEY=sk-ant-...

# Azure DeepSeek (Code Generation)
AZURE_DEEPSEEK_ENDPOINT=https://<resource>.services.ai.azure.com/models
AZURE_DEEPSEEK_KEY=...

# Azure OpenAI (Vision QA)
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
AZURE_OPENAI_KEY=...

# Azure Cognitive Services Speech (TTS)
AZURE_SPEECH_KEY=...
AZURE_SPEECH_REGION=eastus

# Output
BANIM_OUTPUT_DIR=output
BANIM_TEMP_DIR=/tmp/banim
